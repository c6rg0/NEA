{
	"compilerOptions": {
		"strict": true,
		"listEmittedFiles": true,
		"noImplicitAny": true,
		"noUnusedLocals": false,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"noEmitOnError": true,
		"moduleResolution": "node",

		"target": "ES2020",
    		"module": "commonjs",
    		"outDir": "./dist/",
    		"rootDir": "./src/"
	},
  		"include": ["src/server.ts", "src/db", "src/routes"],
  		"exclude": ["src/public/"]
}



