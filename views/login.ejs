<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="UTF-8">
		<title>Login</title>
		<link rel="shortcut icon" href="#">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<link rel="stylesheet" href="/css/style.css">

	</head>
	<body>
		<nav class="navbar navbar-expand-lg">
			<div class="container-fluid">
				<a class="navbar-brand" href="/">Regex practice site</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav nav-underline">
						<li class="nav-item">
							<a class="nav-link" href="/browse">Browse</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/create">Create</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" aria-current="page" href="/account">Account</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>


		<form id="login_form">
			<div class="mb-3">
				<p>
				<label for="username" class="form-label">Username:</label>
				<input name="username" id="username" class="form-control"/>
				</p>
			</div>

			<div class="mb-3">
				<p>
				<label for="password" class="form-label">Password:</label>
				<input name="password" id="password" type="password" class="form-control"/>
				</p>
			<div>

			<div class="button_container">
				<button type="submit" class="form-control">Login</button>
			</div>

		</form>

		<div id="result"></div>
		<p id="exists" style="color: red"></p>
		<p id="length" style="color: red"></p>
		<p id="nums" style="color: red"></p>
		<p id="symbol" style="color: red"></p>

		<script src="js/login.js"></script>

	</body>
</html> 
