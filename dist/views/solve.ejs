<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <title>Solving...</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="#">
  </head>
  <body>

    <nav class="navbar navbar-expand-lg">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Regex practice site</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav nav-underline">
            <li class="nav-item">
              <a class="nav-link" href="/search">Browse</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/create">Create</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" aria-current="page" href="/leaderboard">leaderboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/account">Account</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div id="pre_solution">
      <h1 id="title"><%= info.title %></h1>
      <hr>

      <p id="creator" > Created by: 
      <a href="/user/<%= info.creator %>">
      <%= info.creator %>
      </a></p>

      <% var x = new Date(info.time_created * 1000); %>
      <p>
      Created: <%= x.toDateString() %>
      | Difficulty rating: <%= info.elo %>      
      <% if (auth === true){ %>
      |
      <a href="/delete_problem/<%= info.problem_id %>">
        DELETE?
      </a>
      </p>
      <% } %>
    </div>

    <hr>

    <form id="solution_form" method="dialog">
      <div>
        <p>
        <label for="solution" id="instruction"> Instruction: <%= info.instruction %></label>
        <input name="solution" id="solution" class="form-control"/>
        </p>
      </div>

      <!--<div class="button_container">-->
      <button type="submit" class="btn btn-light">Submit your answer:</button>
      <!--</div>-->
    </form>

    <hr>

    <div id="recent_attempts">
      <p>Recent attempts:</p>
      <% attempts.forEach(i=> { %>
      <p><a href="/user/<%= i.username %>">
        <%= i.username %>
      </a>

      (<%= i.elo %> elo) |

      <%= i.tries %> attempts |

      <% if (i.solved === 1){ %>
      Already solved |
      <% } else { %>
      Unsolved |
      <% } %>

      <% var x = new Date(i.time_submitted * 1000); %>
      <%= x.toDateString() %>
      </p>
      <% }); %>
    </div>

    <div id="button_container" class="button_container"></div>
    <div id="end_screen_container"></div>

    <p id="right_or_wrong"></p>
    <p id="example_data"></p>
    <p id="db_solution"></p>
    <p id="user_attempt"></p>

    <div class="button_container" id="h_button_container" ></div>
    <div class="button_container" id="r_button_container" ></div>

    <script src="/js/solve.js"></script>
  </body>

</html> 
