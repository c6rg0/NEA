<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="UTF-8">
		<title><%= activity %></title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<link rel="stylesheet" href="/css/style.css">
		<link rel="shortcut icon" href="#">
	</head>

	<body>
		<nav class="navbar navbar-expand-lg">
			<div class="container-fluid">
				<a class="navbar-brand" href="/">Regex practice site</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav nav-underline">
						<li class="nav-item">
							<a class="nav-link" aria-current="page" href="/search">Browse</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/create">Create</a>
						</li>						
						<li class="nav-item">
							<a class="nav-link" aria-current="page" href="/leaderboard">leaderboard</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/account">Account</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>


		<form id="search_form">
			<div class="input-group mb-3">
				<input id="search" type="text" class="form-control" placeholder="type in title..." aria-label="type in title..." aria-describedby="button-addon2">
				<input class="btn btn-light" type="submit" id="button-addon2">Search</button>
			</div>
		</form>

		<% if(activity == "after_query"){ %>
			<h3 id="user_search">Results for:  "<%= userSearch %>"</h3>
		<% } %>

		<div class="content">

		<% if(Object.keys(results).length > 0){ %>

			<% results.forEach(i=> { %>
			<p><a href="/solve/<%= i.problem_id %>">
				<%= i.title %>
			</a>
			| <%= i.elo %>
			| <%= i.times_attempted %> attempts
			</p>
			<% }); %>

		<% } else { %>
			<p>nope, nothing found... </p>
		<% } %>

		</div>

		<% if(activity == "Searching"){ %>
		<nav aria-label="Page navigation example">
			<ul class="pagination">
				<li class="page-item"><a id="prev_next" class="page-link" href="<%= back %>">Previous</a></li>
				<li class="page-item"><a id="prev_next" class="page-link" href="<%= forward %>">Next</a></li>
			</ul>
		</nav>
		<% } %>

		<script src="/js/search.js"></script>
	</body>
</html> 
