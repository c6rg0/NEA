{
	"compilerOptions": {
		"strict": true,
		"listEmittedFiles": true,
		"noImplicitAny": true,
		"noUnusedLocals": false,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"noEmitOnError": true,
		"moduleResolution": "node",
		"strictPropertyInitialization": false,

		"target": "es2020",
		"outDir": "./dist/public/js/",
    		"rootDir": "./src/public/"
	},
  		"include": ["src/public/"]
}

